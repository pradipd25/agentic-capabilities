# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: claude | openai | gemini | groq | ollama
LLM_PROVIDER=claude
# Optional: override the default model for the chosen provider
# LLM_MODEL=claude-sonnet-4-6

# ── Agent Backend ─────────────────────────────────────────────────────────────
# pipeline   = single LLM completion (default)
# claude_code = embed Claude Code's agent loop (needs: pip install -e ".[agent]"
#               + ANTHROPIC_API_KEY). Avatar narrates tool steps as action chips.
AGENT_BACKEND=pipeline
# Tool allowlist for claude_code; empty = read-only — Bash/Edit/Write/NotebookEdit
# are blocked (enforced via the SDK's disallowed_tools); the agent can still read
# files. List tools to opt them back in, or "*" to lift the restriction entirely.
# AGENT_ALLOWED_TOOLS=Read,Edit,Bash
# AGENT_ALLOWED_TOOLS=*
# AGENT_PERMISSION_MODE=default

# ── Provider API Keys (only the one matching LLM_PROVIDER is required) ────────
# Note: OPENAI_API_KEY is always required — it powers TTS regardless of LLM_PROVIDER.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
GROQ_API_KEY=gsk_...
OLLAMA_BASE_URL=http://localhost:11434

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8100

# ── Conversation ──────────────────────────────────────────────────────────────
SYSTEM_PROMPT=You are a friendly and helpful AI assistant. Keep responses concise and conversational.
DEFAULT_AVATAR=aria

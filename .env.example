# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: claude | openai | gemini | groq | ollama
LLM_PROVIDER=claude
# Optional: override the default model for the chosen provider
# LLM_MODEL=claude-sonnet-4-6

# ── Provider API Keys (only the one matching LLM_PROVIDER is required) ────────
# Note: OPENAI_API_KEY is always required — it powers TTS regardless of LLM_PROVIDER.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
GROQ_API_KEY=gsk_...
OLLAMA_BASE_URL=http://localhost:11434

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8100

# ── Conversation ──────────────────────────────────────────────────────────────
SYSTEM_PROMPT=You are a friendly and helpful AI assistant. Keep responses concise and conversational.
DEFAULT_AVATAR=aria
